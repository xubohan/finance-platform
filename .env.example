# Database
DB_USER=finuser
DB_PASSWORD=finpass
DB_HOST=db
DB_PORT=5432
DB_HOST_PORT=55432
DB_NAME=finterminal
DATABASE_URL=postgresql+asyncpg://finuser:finpass@db:5432/finterminal

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# API
API_HOST=0.0.0.0
API_PORT=8000
AI_SERVICE_URL=http://ai_service:8001
ENABLE_RESEARCH_APIS=false
ENABLE_AI_API=false
ENABLE_LLM_ANALYSIS=true
ENABLE_NEWS_FETCH=true
ENABLE_CN_DATA=true
INITIALIZE_RUNTIME_SCHEMA=true

# AI provider
ANTHROPIC_API_KEY=
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com
LLM_MODEL=gpt-5.3-codex
LLM_API_STYLE=responses
LLM_ENDPOINT_PATH=/v1/responses
LLM_REASONING_EFFORT=medium
LLM_TEXT_VERBOSITY=low
LLM_TIMEOUT_SEC=60

# Quote providers
QUOTE_PROVIDER_TIMEOUT_SEC=6
QUOTE_PROVIDER_USER_AGENT=finance-platform/0.1
CRYPTO_QUOTE_PROVIDER_ORDER=binance,kraken,coinbase,coingecko
STOCK_QUOTE_PROVIDER_ORDER=finnhub,twelvedata,tencent,yfinance,alphavantage
STOCK_OHLCV_PROVIDER_ORDER=twelvedata,yfinance,stooq
CRYPTO_BINANCE_BASE_URL=https://api.binance.com
CRYPTO_KRAKEN_BASE_URL=https://api.kraken.com
CRYPTO_COINBASE_BASE_URL=https://api.exchange.coinbase.com
CRYPTO_COINGECKO_BASE_URL=https://api.coingecko.com
FINNHUB_API_KEY=
FINNHUB_BASE_URL=https://finnhub.io/api/v1
TWELVEDATA_API_KEY=
TWELVEDATA_BASE_URL=https://api.twelvedata.com
TENCENT_QUOTE_BASE_URL=https://qt.gtimg.cn/q=
ALPHAVANTAGE_API_KEY=
ALPHAVANTAGE_BASE_URL=https://www.alphavantage.co/query
ALPHAVANTAGE_ENTITLEMENT=

# Frontend
VITE_API_BASE_URL=/api/v2
VITE_WS_BASE_URL=ws://localhost/ws
